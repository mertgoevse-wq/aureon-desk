{
  "name": "aureon-desk",
  "version": "0.9.0",
  "description": "Aureon Desk — Windows-first desktop AI workspace with multi-provider chat, prompt intelligence, project workspaces, MCP tools, and secure credential management",
  "main": "./out/main/index.js",
  "author": "Aureon Desk",
  "license": "MIT",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "rebuild:native": "electron-builder install-app-deps",
    "verify:native": "node scripts/verify-native.js",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron .",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "tsx src/main/db/migrate.ts",
    "db:seed": "tsx src/main/db/seed.ts",
    "typecheck:main": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:renderer": "tsc --noEmit -p tsconfig.web.json",
    "typecheck:preload": "tsc --noEmit -p tsconfig.node.json",
    "typecheck": "npm run typecheck:main && npm run typecheck:renderer",
    "lint": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "qa:ai": "npm run typecheck && npm test && npm run build && npm run test:e2e",
    "test:openrouter": "node scripts/test-openrouter.mjs",
    "demo:coding": "node scripts/demo-coding.mjs",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "package": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "drizzle-orm": "^0.45.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "canvas": "^3.2.3",
    "drizzle-kit": "^0.31.0",
    "electron": "^43.0.0",
    "electron-builder": "^25.1.0",
    "electron-vite": "^5.0.0",
    "lucide-react": "^0.468.0",
    "playwright": "^1.61.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.0",
    "react-router-dom": "^7.1.0",
    "rehype-highlight": "^7.0.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.1.0",
    "vitest": "^3.1.0",
    "zustand": "^5.0.0"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true,
    "esbuild@0.18.20": true,
    "esbuild@0.25.12": true,
    "esbuild@0.28.1": true
  }
}
